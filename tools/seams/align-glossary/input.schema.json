{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "seam://align-glossary/input",
  "title": "AlignGlossaryInput",
  "type": "object",
  "required": ["spec_body", "glossary_table"],
  "additionalProperties": false,
  "properties": {
    "spec_body": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50000,
      "description": "Markdown spec body to scan for glossary drift"
    },
    "glossary_table": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["term"],
        "additionalProperties": false,
        "properties": {
          "term": { "type": "string", "minLength": 1 },
          "aliases": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "default": []
          },
          "definition": { "type": "string" }
        }
      }
    },
    "context_path": {
      "type": "string",
      "description": "Optional source path for diagnostics"
    }
  }
}
