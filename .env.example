# Copy to .env (not committed) and export variables in your shell, or use a loader.
# Optional: repo-root .env.local (gitignored) with DATABASE_URL= — Unity Editor reads it for TECH-55b registry scripts.
# Never commit real passwords or production connection strings.

# PostgreSQL connection URI for TECH-44b IA tables (glossary, spec_sections, invariants, relationships).
# Overrides committed defaults in config/postgres-dev.json when non-empty.
# Territory IA dev default in config/postgres-dev.json uses host port 5434 (see docs/postgres-ia-dev-setup.md).
# Example: postgresql://postgres:postgres@localhost:5434/territory_ia_dev
DATABASE_URL=

# Optional: Unity editor binary for root `npm run unity:compile-check` (batchmode compile smoke).
# Do not run compile-check while Unity Editor has the same project open (project lock).
# macOS example: /Applications/Unity/Hub/Editor/2022.3.62f3/Unity.app/Contents/MacOS/Unity
# UNITY_EDITOR_PATH=

# Optional: cap for tools/postgres-ia seed-glossary-sample.mjs (default 20)
# SEED_GLOSSARY_MAX=20
