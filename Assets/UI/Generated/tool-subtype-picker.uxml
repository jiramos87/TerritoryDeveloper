<?xml version="1.0" encoding="utf-8"?>
<ui:UXML
    xmlns:ui="UnityEngine.UIElements"
    xmlns:uie="UnityEditor.UIElements"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd"
    editor-extension-mode="False">
  <!-- Panel: tool-subtype-picker | kind: hud | theme: cream -->
  <Style src="tool-subtype-picker.uss"/>
  <ui:VisualElement name="tool-subtype-picker" class="tool-subtype-picker">
    <ui:VisualElement name="tier-row" class="tool-subtype-picker__tier-row">
      <ui:Button name="tier-card-0" class="tool-subtype-picker__tier-card">
        <ui:Label name="tier-card-0-label" class="tool-subtype-picker__tier-label" text="Light"/>
      </ui:Button>
      <ui:Button name="tier-card-1" class="tool-subtype-picker__tier-card">
        <ui:Label name="tier-card-1-label" class="tool-subtype-picker__tier-label" text="Medium"/>
      </ui:Button>
      <ui:Button name="tier-card-2" class="tool-subtype-picker__tier-card">
        <ui:Label name="tier-card-2-label" class="tool-subtype-picker__tier-label" text="Heavy"/>
      </ui:Button>
    </ui:VisualElement>
  </ui:VisualElement>
</ui:UXML>
