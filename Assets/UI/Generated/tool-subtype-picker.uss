.tool-subtype-picker__tier-card--zone-i-medium { background-image: url("project://database/Assets/Sprites/Industrial/medium-industrial-building-1-128.png"); }
.tool-subtype-picker__tier-card--zone-i-heavy  { background-image: url("project://database/Assets/Sprites/Industrial/heavy-industrial-building-1-192.png"); }

