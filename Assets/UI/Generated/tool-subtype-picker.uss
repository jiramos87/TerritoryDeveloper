/* Panel: tool-subtype-picker | kind: hud | theme: cream */
/* Iter-3 — literal hex + per-parent tier-card sprite mapping. */

.tool-subtype-picker {
    position: absolute;
    left: 108px;
    bottom: 16px;
    flex-direction: column;
    background-color: #f5e6c8;
    border-color: #b89b5e;
    border-width: 2px;
    border-radius: 6px;
    padding: 6px;
    display: none;
}

.tool-subtype-picker.is-open {
    display: flex;
}

.tool-subtype-picker__tier-row {
    flex-direction: row;
    align-items: center;
}

.tool-subtype-picker__tier-card {
    width: 64px;
    height: 64px;
    background-color: #ede4ce;
    border-color: #b89b5e;
    border-width: 1px;
    border-radius: 4px;
    margin: 3px;
    padding: 0;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    -unity-background-scale-mode: scale-to-fit;
}

.tool-subtype-picker__tier-card:hover {
    border-color: #d4b87a;
    background-color: #f9efd2;
}

.tool-subtype-picker__tier-card--active {
    border-color: #5b7fa8;
    border-width: 3px;
}

.tool-subtype-picker__tier-label {
    color: #3a2f1c;
    font-size: 9px;
    -unity-text-align: middle-center;
    -unity-font-style: bold;
    background-color: rgba(245, 230, 200, 0.85);
    padding: 0 3px;
    margin-bottom: 2px;
}

/* zone-r — zoning tiles (not buildings — clicking creates a zone, building grows later) */
.tool-subtype-picker__tier-card--zone-r-light  { background-image: url("project://database/Assets/Sprites/Residential/residential-light-zoning-64.png"); }
.tool-subtype-picker__tier-card--zone-r-medium { background-image: url("project://database/Assets/Sprites/Residential/residential-medium-zoning-64.png"); }
.tool-subtype-picker__tier-card--zone-r-heavy  { background-image: url("project://database/Assets/Sprites/Residential/residential-heavy-zoning-64.png"); }

/* zone-c — zoning tiles */
.tool-subtype-picker__tier-card--zone-c-light  { background-image: url("project://database/Assets/Sprites/Commercial/commercial-light-zoning-64.png"); }
.tool-subtype-picker__tier-card--zone-c-medium { background-image: url("project://database/Assets/Sprites/Commercial/commercial-medium-zoning-64.png"); }
.tool-subtype-picker__tier-card--zone-c-heavy  { background-image: url("project://database/Assets/Sprites/Commercial/commercial-heavy-zoning-64.png"); }

/* zone-i — zoning tiles */
.tool-subtype-picker__tier-card--zone-i-light  { background-image: url("project://database/Assets/Sprites/Industrial/industrial-light-zoning-64.png"); }
.tool-subtype-picker__tier-card--zone-i-medium { background-image: url("project://database/Assets/Sprites/Industrial/industrial-medium-zoning-64.png"); }
.tool-subtype-picker__tier-card--zone-i-heavy  { background-image: url("project://database/Assets/Sprites/Industrial/industrial-heavy-zoning-64.png"); }

/* services */
