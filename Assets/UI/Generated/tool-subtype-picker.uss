/* Panel: tool-subtype-picker | kind: hud | theme: cream */
/* Iter-3 — literal hex + per-parent tier-card sprite mapping. */

.tool-subtype-picker {
    position: absolute;
    left: 184px;
    bottom: 20px;
    flex-direction: column;
    background-color: #f5e6c8;
    border-color: #b89b5e;
    border-width: 2px;
    border-radius: 10px;
    padding: 10px;
    display: none;
}

.tool-subtype-picker.is-open {
    display: flex;
}

.tool-subtype-picker__tier-row {
    flex-direction: row;
    align-items: center;
}

.tool-subtype-picker__tier-card {
    width: 96px;
    height: 96px;
    background-color: #ede4ce;
    border-color: #b89b5e;
    border-width: 2px;
    border-radius: 6px;
    margin: 4px;
    padding: 0;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    -unity-background-scale-mode: scale-to-fit;
}

.tool-subtype-picker__tier-card:hover {
    border-color: #d4b87a;
    background-color: #f9efd2;
}

.tool-subtype-picker__tier-card--active {
    border-color: #5b7fa8;
    border-width: 3px;
}

.tool-subtype-picker__tier-label {
    color: #3a2f1c;
    font-size: 11px;
    -unity-text-align: middle-center;
    -unity-font-style: bold;
    background-color: rgba(245, 230, 200, 0.85);
    padding: 1px 4px;
    margin-bottom: 4px;
}

/* zone-r */
.tool-subtype-picker__tier-card--zone-r-light  { background-image: url("project://database/Assets/Sprites/Residential/light-residential-building-2-128.png"); }
.tool-subtype-picker__tier-card--zone-r-medium { background-image: url("project://database/Assets/Sprites/Residential/medium-residential-building-2-128.png"); }
.tool-subtype-picker__tier-card--zone-r-heavy  { background-image: url("project://database/Assets/Sprites/Residential/heavy-residential-building-1-64.png"); }

/* zone-c */
.tool-subtype-picker__tier-card--zone-c-light  { background-image: url("project://database/Assets/Sprites/Commercial/light-commercial-building-2-128.png"); }
.tool-subtype-picker__tier-card--zone-c-medium { background-image: url("project://database/Assets/Sprites/Commercial/commercial-medium-building-64-1.png"); }
.tool-subtype-picker__tier-card--zone-c-heavy  { background-image: url("project://database/Assets/Sprites/Commercial/dense-commercial-tall.png"); }

/* zone-i */
