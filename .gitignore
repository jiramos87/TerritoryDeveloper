# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
# VS Code / Cursor: ignore local-only files; commit shared workspace defaults
.vscode/*
!.vscode/settings.json
.idea
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage

# Crashlytics generated file
crashlytics-build.properties

# tools/reports — local-only artifacts (Unity compile logs, snapshots, bridge exports, staging).
# Not versioned: they are large, machine-specific, and reproducible from Editor/scripts when needed.
tools/reports/**
!tools/reports/
!tools/reports/.gitkeep
!tools/reports/compute-utilities-inventory.md
!tools/reports/compute-utilities-rng-derivation.md
# Node — all workspaces (tools/*, web/, root)
node_modules/

# MCP IA server build artifacts
tools/mcp-ia-server/dist/
tools/mcp-ia-server/coverage/
tools/mcp-ia-server/.cache/

# Local env (never commit secrets)
.env
.env.local

# Agent / Editor one-shot test-mode queue (scenario load)
tools/fixtures/scenarios/.queued-test-scenario-id
/.queued-test-scenario-id

# Harness-agnostic runtime state (per clone; schema + example committed)
ia/state/runtime-state.json
# Ad-hoc agent-written GameSaveData fixtures (run-scoped directories)
tools/fixtures/scenarios/agent-generated/

# sprite-gen scratch render dir — gitignored; promote flow copies to Assets/Sprites/Generated/
tools/sprite-gen/out/
# Python bytecode
__pycache__/
*.pyc
.vercel

# Playwright output (opt-in; not part of validate:all)
web/playwright-report/

# Agent audit blobs — session-token-latency Theme 0
Bury_*.json
mono_crash.*

# Agent telemetry — raw captures excluded, summaries tracked
.claude/telemetry/*.jsonl
!.claude/telemetry/*-summary.json

# Local-only mutable state — DB snapshots, scratch dumps. Reproducible from db:snapshot:freeze.
var/

var/blobs/

!var/blobs/.gitkeep

# Per-user Unity editor layout — not shared across machines
UserSettings/Layouts/

# Local runtime stderr logs (cron-server, etc.)
tools/cron-server/launchd/*.err

# Nested mcp-ia-server cache (parse-cache.json under tools/mcp-ia-server/tools/mcp-ia-server/.cache/)
tools/mcp-ia-server/tools/mcp-ia-server/.cache/

# Local sqlite DB — session state, reproducible from migrations
ia/state/ia.db

# Claude Code scheduled-task lock
.claude/scheduled_tasks.lock
