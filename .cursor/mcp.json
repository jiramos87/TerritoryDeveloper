{
  "mcpServers": {
    "territory-ia": {
      "command": "node",
      "args": ["tools/mcp-ia-server/bin/launch.mjs"],
      "env": {
        "REPO_ROOT": ".",
        "DEBUG_MCP_COMPUTE": "1",
        "MCP_SPLIT_SERVERS": "0"
      }
    },
    "territory-ia-bridge": {
      "command": "node",
      "args": ["tools/mcp-ia-server/bin/launch.mjs"],
      "env": {
        "REPO_ROOT": ".",
        "DEBUG_MCP_COMPUTE": "1",
        "MCP_ENTRY": "index-bridge"
      }
    }
  }
}
