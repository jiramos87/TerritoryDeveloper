{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "territory-developer:schemas/cell-chunk-interchange.v1",
  "title": "Terrain cell chunk interchange (v1)",
  "description": "Axis-aligned chunk subset for tooling (TECH-41 G2). Not Save data.",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact", "schema_version", "origin_x", "origin_y", "width", "height", "cells"],
  "properties": {
    "artifact": {
      "type": "string",
      "const": "terrain_cell_chunk",
      "description": "Logical model id for validators and agents."
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "origin_x": { "type": "integer", "minimum": 0 },
    "origin_y": { "type": "integer", "minimum": 0 },
    "width": { "type": "integer", "minimum": 1 },
    "height": { "type": "integer", "minimum": 1 },
    "notes": { "type": "string" },
    "cells": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["x", "y", "height", "prefabName", "waterBodyType", "waterBodyId"],
        "properties": {
          "x": { "type": "integer", "minimum": 0 },
          "y": { "type": "integer", "minimum": 0 },
          "height": { "type": "integer" },
          "prefabName": { "type": "string" },
          "waterBodyType": { "type": "string" },
          "waterBodyId": { "type": "integer" }
        }
      }
    }
  }
}
