// ============== DECISION MATRIX ==============
const DECISIONS = [
  { id: 'Q1',  topic: 'Migration shape', pick: 'Full strangler — uGUI deletion own future stage', rationale: 'All 51 panels migrate one-by-one; final uGUI purge sweep gets its own plan to keep blast radius bounded.' },
  { id: 'Q2',  topic: 'Bake emitter strategy', pick: 'Side-by-side UxmlBakeHandler class', rationale: 'Zero schema churn on panel_detail. Existing UiBakeHandler untouched during transition. Flag at consumer site.' },
  { id: 'Q3',  topic: 'Themed primitive fate', pick: 'Port simple, retire complex case-by-case', rationale: 'ThemedLabel/Divider/Badge → USS classes (retire). ThemedButton/Frame/List/TabBar → [UxmlElement] ports.' },
  { id: 'Q4',  topic: 'Studio controls', pick: 'Defer indefinitely', rationale: 'Knob / Fader / VU / Oscilloscope stay uGUI. Out of scope for parity migration; separate plan owns procedural rendering port.' },
  { id: 'Q5',  topic: 'Token storage', pick: 'DB row canonical + generated TSS files', rationale: 'Preserves DB-primary invariant. TSS is derived artifact, identical pattern to prefab today.' },
  { id: 'Q6',  topic: 'Data binding', pick: 'Replace per-panel with native binding', rationale: 'Adapter → ViewModel + INotifyPropertyChanged + dataBindingPath at migration time. UiBindRegistry retires when last consumer flips.' },
  { id: 'Q7',  topic: 'Pilot panel', pick: 'pause-menu, then hud-bar', rationale: 'Pilot = lowest-risk template (Stage 1 tracer slice). Stage 2 = real-world live-state stress before sweep.' },
  { id: 'Q8',  topic: 'Stage granularity', pick: 'Tracer slice + horizontal sweep', rationale: 'Stage 1 = single panel end-to-end (bake emitter, host, VM, TSS, scene swap). Stages 2+ = batched sweeps by archetype × scene.' },
  { id: 'Q9',  topic: 'World-space UI', pick: 'Document target shape, defer impl', rationale: 'World-space UI sketch in design doc; no acceptance gate. Owned by its own plan.' },
  { id: 'Q10', topic: 'Visual regression', pick: 'Hybrid — manual for pilot, automated for sweep', rationale: 'Pilot stage = visual review by user. Pilot also builds pixel-diff harness. Sweep stages run automated.' },
  { id: 'Q11', topic: 'Atomization dep', pick: 'Interleave — atomize bake emitter slot first', rationale: 'ui-bake-handler-atomization lands IPanelEmitter seam → UxmlBakeHandler slots in cleanly.' },
  { id: 'Q12', topic: 'Done criterion', pick: '(a)+(b)+(c)', rationale: 'All 51 prefabs replaced AND no Canvas/CanvasRenderer/RectTransform in Assets/Scripts/UI/** AND UiBindRegistry removed. World-space demo NOT in gate.' },
];
const decisionGrid = document.getElementById('decisionGrid');
