  const id = 'stage-' + s.id.replace(/\./g, '-');
  li.innerHTML = `<a href="#${id}">Stage ${s.id} — ${s.title.substring(0, 36)}${s.title.length > 36 ? '…' : ''}</a>`;
  tocList.appendChild(li);
  tocItems.push({ el: li.firstChild, target: id });
});

// Auto-id headings + add to TOC
let hIdx = 0;
document.querySelectorAll('#bodyContent h1, #bodyContent h2, #bodyContent h3').forEach(h => {
  const id = 'h-' + (hIdx++) + '-' + h.textContent.toLowerCase().replace(/[^a-z0-9]+/g, '-').substring(0, 40);
  h.id = id;
  const li = document.createElement('li');
  li.className = h.tagName === 'H3' ? 'lvl-3' : '';
  li.innerHTML = `<a href="#${id}">${h.textContent}</a>`;
  tocList.appendChild(li);
  tocItems.push({ el: li.firstChild, target: id });
});

// TOC search
document.getElementById('tocSearch').addEventListener('input', (e) => {
  const q = e.target.value.toLowerCase();
  tocList.querySelectorAll('li').forEach(li => {
    li.classList.toggle('hidden', q && !li.textContent.toLowerCase().includes(q));
  });
});

// Expand/collapse all
document.getElementById('expandAll').onclick = () => document.querySelectorAll('.stage-card').forEach(d => d.open = true);
document.getElementById('collapseAll').onclick = () => document.querySelectorAll('.stage-card').forEach(d => d.open = false);

// Light/dark toggle
document.getElementById('toggleTheme').onclick = () => {
  const root = document.documentElement;
  const isLight = root.style.getPropertyValue('--bg') === '#ffffff';
  if (isLight) {
    root.style.cssText = '';
  } else {
    root.style.setProperty('--bg', '#ffffff');
    root.style.setProperty('--bg-elev', '#f6f8fa');
    root.style.setProperty('--bg-card', '#ffffff');
    root.style.setProperty('--fg', '#1f2328');
    root.style.setProperty('--fg-dim', '#656d76');
    root.style.setProperty('--border', '#d0d7de');
    root.style.setProperty('--code-bg', '#f6f8fa');
  }
};

// Scrollspy
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      tocItems.forEach(it => {
        if (it.target === entry.target.id) it.el.classList.add('active');
        else it.el.classList.remove('active');
      });
    }
  });
}, { rootMargin: '-30% 0px -60% 0px' });
tocItems.forEach(it => {
  const target = document.getElementById(it.target);
  if (target) observer.observe(target);
});
