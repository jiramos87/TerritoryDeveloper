{
  "name": "territory-developer",
  "private": true,
  "workspaces": [
    "web",
    "tools/*"
  ],
  "description": "Unity project root scripts delegate to tools/mcp-ia-server (IA / JSON tooling). Local post-implementation checks: npm run verify:local (canonical) — validate:all (includes territory-compute-lib build) then Unity/Postgres bridge chain; npm run verify:post-implementation is an alias. Run npm ci in tools/compute-lib / tools/mcp-ia-server if build or test:ia fails. Bridge-only: npm run db:bridge-playmode-smoke. Local compile smoke: npm run unity:compile-check (loads repo-root .env/.env.local via tools/scripts/load-repo-env.inc.sh; macOS can fall back to Unity Hub path from ProjectSettings/ProjectVersion.txt — AI agents must not skip this because $UNITY_EDITOR_PATH is empty in the shell). Test mode batch load: npm run unity:testmode-batch (tools/scripts/unity-testmode-batch.sh). Scenario builder: npm run unity:build-scenario-from-descriptor, npm run scenario:build-from-descriptor.",
  "scripts": {
    "compute-lib:build": "npm --prefix tools/compute-lib run build",
    "validate:runtime-state": "node tools/scripts/validate-runtime-state.mjs",
    "validate:all": "npm run validate:master-plan-status && npm run validate:arch-coherence && npm run validate:backlog-yaml && npm run compute-lib:build && npm run test:ia && npm run validate:fixtures && npm run validate:backfill-fixtures && npm run generate:ia-indexes -- --check && npm run validate:web:conditional && npm run validate:telemetry-schema && npm run validate:runtime-state && npm run validate:cache-block-sizing && npm run validate:claude-imports && npm run validate:capability-coverage && npm run validate:sprite-gen-schema && npm run validate:blob-roots && npm run validate:agent-tools-uniformity && npm run validate:agent-tools && npm run validate:skill-drift && npm run validate:skill-changelog-presence && npm run validate:mcp-readme && npm run validate:mcp-descriptor-prose && npm run validate:seam-golden && npm run validate:recipe-drift && npm run validate:skill-recipe-drift && npm run test:recipe-engine && npm run smoke:seam-q5 && npm run validate:mcp-catalog-coverage",
    "smoke:seam-q5": "node --import tsx tools/scripts/smoke-seam-q5.mjs",
    "validate:seam-golden": "node tools/scripts/validate-seam-golden.mjs",
    "validate:recipe-drift": "node tools/scripts/validate-recipe-drift.mjs",
    "validate:skill-recipe-drift": "npx tsx tools/scripts/skill-tools/validate-skill-recipe-drift.ts",
    "test:recipe-engine": "node tools/recipe-engine/selftest.mjs",
    "validate:skill-changelog-presence": "node tools/scripts/validate-skill-changelog-presence.mjs",
    "recipe:run": "npx tsx tools/recipe-engine/src/cli.ts",
    "validate:claude-imports": "npx tsx tools/scripts/validate-claude-imports.ts",
    "validate:capability-coverage": "npx tsx tools/scripts/validate-capability-coverage.ts",
    "validate:sprite-gen-schema": "npx tsx tools/scripts/validate-sprite-gen-schema.ts",
    "validate:blob-roots": "npx tsx tools/scripts/validate/validate-blob-roots.ts",
    "validate:trgm-indexes": "npx tsx tools/scripts/validate-trgm-indexes.ts",
    "validate:mcp-catalog-coverage": "npx tsx tools/scripts/validate-mcp-catalog-coverage.ts",
    "validate:mcp-readme": "node tools/scripts/validate-mcp-readme.mjs",
    "validate:mcp-descriptor-prose": "node tools/scripts/validate-mcp-descriptor-prose.mjs",
    "validate:cache-block-sizing": "npx tsx tools/scripts/validate-cache-block-sizing.ts",
    "validate:agent-tools-uniformity": "npx tsx tools/scripts/validate-agent-tools-uniformity.ts",
    "validate:agent-tools": "npx tsx tools/scripts/validate-agent-tools.ts",
    "validate:telemetry-schema": "node tools/scripts/validate-telemetry-schema.mjs",
    "validate:master-plan-status": "node tools/validate-master-plan-status.mjs",
    "validate:arch-coherence": "node tools/scripts/validate-arch-coherence.mjs",
    "validate:master-plan-health-rollup": "node tools/scripts/validate-master-plan-health-rollup.mjs",
    "validate:web": "npm --prefix web run lint && npm --prefix web run typecheck && npm --prefix web run test && npm --prefix web run build",
    "validate:web:conditional": "bash tools/scripts/validate-web-conditional.sh",
    "validate:web:build": "npm run validate:web",
    "validate:backlog-yaml": "npx tsx tools/validate-backlog-yaml.ts",
    "validate:catalog-dto": "node tools/scripts/catalog-dto-migration-check.mjs",
    "validate:catalog-spine": "npx tsx tools/postgres-ia/validate-catalog-spine.ts",
    "catalog:export": "npm --prefix web run catalog:export",
    "catalog:export:check": "npm --prefix web run catalog:export:check",
    "validate:frontmatter": "node tools/mcp-ia-server/scripts/check-frontmatter.mjs",
    "validate:fixtures": "npm --prefix tools/mcp-ia-server run validate:fixtures",
    "validate:backfill-fixtures": "bash tools/scripts/test/backfill-locator-fixtures.sh",
    "validate:geography-init-report": "node tools/scripts/validate-geography-init.mjs",
    "generate:ia-indexes": "cd tools/mcp-ia-server && npx tsx scripts/generate-ia-indexes.ts",
    "skill:sync": "tsx tools/scripts/skill-tools/index.ts sync",
    "skill:sync:all": "tsx tools/scripts/skill-tools/index.ts sync:all --apply",
    "skill:lint": "tsx tools/scripts/skill-tools/index.ts lint",
    "validate:skill-drift": "tsx tools/scripts/skill-tools/index.ts lint --json --strict",
    "test:skill-tools": "npx tsx --test tools/scripts/skill-tools/__tests__/*.test.ts",
    "test:ia": "npm --prefix tools/mcp-ia-server test",
    "test:scripts": "npx tsx --test tools/scripts/__tests__/extract-cd-tokens.test.ts && npx tsx --test tools/scripts/__tests__/extract-cd-interactions.test.ts && npx tsx --test tools/scripts/__tests__/extract-cd-computed-styles.test.ts && npx tsx --test tools/scripts/__tests__/extract-cd-layout-rects.test.ts && npx tsx --test tools/scripts/__tests__/transcribe-cd-game-ui.test.ts && npx tsx --test tools/scripts/__tests__/unity-bake-ui.smoke.test.ts && npx tsx --test web/lib/catalog/stable-json-stringify.test.ts",
    "transcribe:cd-game-ui": "npx tsx tools/scripts/transcribe-cd-game-ui.ts",
    "test:mcp-split": "cd tools/mcp-ia-server && node --import tsx --test tests/server-split.test.ts",
    "db:migrate": "npm --prefix tools/postgres-ia run migrate",
    "audit:master-plan-change-log-dups": "node tools/scripts/audit-master-plan-change-log-dups.mjs",
    "claims:sweep:tick": "node tools/scripts/claims-sweep-tick.mjs",
    "ia:db-import": "npx tsx tools/mcp-ia-server/scripts/ia-db-import.ts",
    "db:setup-local": "bash tools/scripts/setup-territory-ia-postgres.sh",
    "db:seed:glossary": "npm --prefix tools/postgres-ia run seed:glossary",
    "db:glossary": "npm --prefix tools/postgres-ia run glossary-by-key --",
    "db:register-repro": "npm --prefix tools/postgres-ia run register-repro --",
    "db:register-editor-export": "npm --prefix tools/postgres-ia run register-editor-export --",
    "closeout:worksheet": "cd tools/mcp-ia-server && npx tsx scripts/project-spec-closeout-report.ts --",
    "closeout:dependents": "cd tools/mcp-ia-server && npx tsx scripts/project-spec-dependents.ts --",
    "closeout:verify": "npm run generate:ia-indexes -- --check",
    "db:persist-project-journal": "cd tools/mcp-ia-server && npx tsx scripts/persist-project-spec-journal.ts --",
    "db:bridge-agent-context": "npx --prefix tools/mcp-ia-server tsx tools/mcp-ia-server/scripts/run-unity-bridge-once.ts",
    "db:bridge-preflight": "npx tsx tools/mcp-ia-server/scripts/bridge-preflight.ts",
    "db:bridge-playmode-smoke": "npm --prefix tools/mcp-ia-server run bridge-playmode-smoke --",
    "db:snapshot": "node tools/postgres-ia/snapshot-ia-db.mjs",
    "db:snapshot:smoke": "node tools/postgres-ia/restore-snapshot-smoke.mjs",
    "db:snapshot:freeze": "bash tools/scripts/freeze-db-snapshot.sh pre-spine",
    "db:snapshot:restore": "bash tools/scripts/restore-db-snapshot.sh",
    "db:audit-pre-spine": "npm run db:snapshot:freeze && npx tsx tools/postgres-ia/audit-catalog-pre-spine.ts",
    "unity:ensure-editor": "bash tools/scripts/ensure-unity-editor.sh",
    "unity:compile-check": "bash tools/scripts/unity-compile-check.sh",
    "unity:test-editmode": "bash tools/scripts/unity-run-tests.sh --platform editmode --quit-editor-first",
    "unity:test-playmode": "bash tools/scripts/unity-run-tests.sh --platform playmode --quit-editor-first",
    "unity:test-all": "npm run unity:test-editmode && npm run unity:test-playmode",
    "unity:testmode-batch": "bash tools/scripts/unity-testmode-batch.sh",
    "unity:build-scenario-from-descriptor": "bash tools/scripts/unity-build-scenario-from-descriptor.sh",
    "unity:bake-ui": "tsx tools/scripts/unity-bake-ui.ts",
    "scenario:build-from-descriptor": "node tools/fixtures/scenarios/build-scenario-from-descriptor.mjs",
    "verify:local": "bash tools/scripts/verify-local.sh",
    "verify:post-implementation": "npm run verify:local",
    "backfill:arch-surfaces": "node tools/scripts/backfill-arch-surfaces.mjs",
    "progress": "node tools/progress-tracker/index.mjs",
    "deploy:web": "bash tools/scripts/vercel-deploy.sh",
    "deploy:web:preview": "bash tools/scripts/vercel-deploy.sh --preview",
    "validate:e2e": "npm --prefix web run test:e2e:ci",
    "render:worker": "npx tsx tools/scripts/render-worker.ts"
  },
  "engines": {
    "node": ">=20.6"
  },
  "volta": {
    "node": "22.18.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@types/babel__traverse": "^7.28.0",
    "glob": "^13.0.6",
    "playwright": "^1.59.1",
    "ts-morph": "^28.0.0"
  }
}
